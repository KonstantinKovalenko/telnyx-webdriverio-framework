{
  "name": "5t-wdio-telnyx",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/types": "^9.29.1",
    "allure-commandline": "^2.43.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "expect-webdriverio": "^5.7.0",
    "geckodriver": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "test": "npm run chrome",

    "chrome": "wdio run config/wdio.chrome.conf.ts",
    "firefox": "wdio run config/wdio.firefox.conf.ts",
    "edge": "wdio run config/wdio.edge.conf.ts",

    "solo": "wdio run config/wdio.chrome.conf.ts --spec ./tests/05-error/18-error-pages.spec.ts",

    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clean": "rimraf allure-results allure-report",
    "allure": "npm run allure:generate && npm run allure:open"
  }
}